<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CriminalIntent" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryDark">@color/orange_variant</item>
        <item name="colorAccent">@color/orange_accent</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/black</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/black</item>

        <!-- Action bar styling to prevent overlapping content -->
        <item name="windowActionBarOverlay">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/orange_accent</item>

        <!-- Button styles -->
        <item name="buttonStyle">@style/Widget.CriminalIntent.Button</item>

        <!-- Dialog Theme -->
        <item name="alertDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
        <item name="android:datePickerDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
        <item name="android:timePickerDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
    </style>

    <style name="Widget.CriminalIntent.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@color/black</item>
        <item name="android:textColor">@color/orange_primary</item>
    </style>

    <style name="Theme.CriminalIntent.AlertDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <!-- Set a slightly lighter background for the dialog content -->
        <item name="android:colorBackground">#333333</item>
        <item name="colorAccent">@color/orange_primary</item>

        <!-- Ensure text colors are white -->
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/orange_accent</item>

        <!-- Fix for list items in AlertDialog -->
        <item name="android:textColorAlertDialogListItem">@color/white</item>

        <!-- TimePicker styling -->
        <item name="android:timePickerStyle">@style/Widget.CriminalIntent.TimePicker</item>
        <item name="android:headerBackground">@color/orange_primary</item>
        <item name="android:numbersTextColor">@color/black</item>
        <item name="android:numbersInnerTextColor">@color/black</item>
        <item name="android:numbersSelectorColor">@color/orange_primary</item>
        <item name="android:numbersBackgroundColor">#DDDDDD</item>
        <item name="android:amPmTextColor">@color/black</item>
    </style>

    <style name="Widget.CriminalIntent.TimePicker" parent="android:Widget.Material.TimePicker">
        <item name="android:numbersTextColor">@color/black</item>
        <item name="android:numbersInnerTextColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/black</item>
        <item name="android:numbersSelectorColor">@color/orange_primary</item>
        <item name="android:numbersBackgroundColor">#DDDDDD</item>
    </style>

    <style name="Theme.CriminalIntent" parent="Base.Theme.CriminalIntent" />
</resources>
