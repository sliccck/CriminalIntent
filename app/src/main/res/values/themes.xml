<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CriminalIntent" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryDark">@color/orange_variant</item>
        <item name="colorAccent">@color/orange_accent</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/black</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/black</item>

        <!-- Action bar styling to prevent overlapping content -->
        <item name="windowActionBarOverlay">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/orange_accent</item>

        <!-- Button styles -->
        <item name="buttonStyle">@style/Widget.CriminalIntent.Button</item>

        <!-- Dialog Themes -->
        <item name="alertDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
        <item name="android:datePickerDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
        <item name="android:timePickerDialogTheme">@style/Theme.CriminalIntent.AlertDialog</item>
    </style>

    <style name="Widget.CriminalIntent.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@color/black</item>
        <item name="android:textColor">@color/orange_primary</item>
    </style>

    <style name="Theme.CriminalIntent.AlertDialog" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <!-- Set a dark background for the dialog -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">#222222</item>

        <!-- Primary accent color (Header, selection circles) -->
        <item name="colorAccent">@color/orange_primary</item>

        <!-- Text visibility fixes -->
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/orange_accent</item>
        <item name="android:textColorAlertDialogListItem">@color/white</item>

        <!-- Fix for buttons (OK/CANCEL) -->
        <item name="buttonBarPositiveButtonStyle">@style/Widget.CriminalIntent.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.CriminalIntent.Button.Dialog</item>

        <!-- Specific Widget Styles -->
        <item name="android:datePickerStyle">@style/Widget.CriminalIntent.DatePicker</item>
        <item name="android:timePickerStyle">@style/Widget.CriminalIntent.TimePicker</item>
    </style>

    <style name="Widget.CriminalIntent.Button.Dialog" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/orange_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.CriminalIntent.DatePicker" parent="android:Widget.Material.DatePicker">
        <item name="android:headerBackground">@color/orange_primary</item>
        <item name="android:calendarTextColor">@color/white</item>
        <item name="android:dayOfWeekBackground">@color/orange_variant</item>
        <item name="android:dayOfWeekTextAppearance">@style/Widget.CriminalIntent.DatePicker.DayOfWeek</item>
        <item name="android:yearListItemTextAppearance">@style/Widget.CriminalIntent.DatePicker.Year</item>
        <item name="android:yearListSelectorColor">@color/orange_primary</item>
    </style>

    <style name="Widget.CriminalIntent.DatePicker.DayOfWeek" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CriminalIntent.DatePicker.Year" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.CriminalIntent.TimePicker" parent="android:Widget.Material.TimePicker">
        <item name="android:headerBackground">@color/orange_primary</item>
        <item name="android:numbersTextColor">@color/white</item>
        <item name="android:numbersInnerTextColor">#CCCCCC</item>
        <item name="android:numbersSelectorColor">@color/orange_primary</item>
        <item name="android:numbersBackgroundColor">#444444</item>
        <item name="android:amPmTextColor">@color/white</item>
    </style>

    <style name="Theme.CriminalIntent" parent="Base.Theme.CriminalIntent" />
</resources>
